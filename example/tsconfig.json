{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["../src/*"],
      "@feihan-im/sdk": ["../src/index.ts"],
      "@feihan-im/sdk/*": ["../src/*"]
    }
  },
  "include": ["./**/*"]
}
