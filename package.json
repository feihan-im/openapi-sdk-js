{
  "name": "@feihan-im/sdk",
  "version": "0.28.105",
  "description": "飞函官方 OpenAPI SDK，支持 Node.js 和 Browser",
  "author": "上海飞函安全科技有限公司",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["feihan", "飞函", "sdk", "im", "rtc", "drive", "self-hosted"],
  "license": "Apache-2.0",
  "homepage": "https://feihanim.cn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feihan-im/openapi-sdk-js.git"
  },
  "bugs": {
    "url": "https://github.com/feihan-im/openapi-sdk-js/issues"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
